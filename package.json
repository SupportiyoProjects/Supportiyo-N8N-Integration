{
  "name": "n8n-nodes-supportiyo",
  "version": "0.1.9",
  "description": "n8n community node for the Supportiyo API",
  "license": "MIT",
  "homepage": "https://github.com/SupportiyoProjects/Supportiyo-N8N-Integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/SupportiyoProjects/Supportiyo-N8N-Integration.git"
  },
  "author": {
    "name": "Supportiyo",
    "email": "ahmed@supportiyo.support"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
